# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brindin

# Redis
REDIS_URL=redis://localhost:6379

# AI Services
ANTHROPIC_API_KEY=sk-ant-xxxxx
SARVAM_API_KEY=sk-sarvam-xxxxx

# Cloudflare R2 (production)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=brindin-assets

# For local dev with Docker Compose (MinIO):
# R2_ENDPOINT=http://localhost:9000
# R2_ACCESS_KEY=minioadmin
# R2_SECRET_KEY=minioadmin

# Server
PORT=3001

# API Authentication
API_KEY=dev-key
